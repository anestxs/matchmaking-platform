enum TournamentStatus {
    REGISTRATION
    ONGOING
    COMPLETED
    CANCELLED
}

enum TournamentFormat {
    SINGLE_ELIMINATION
}

enum EntrySource {
    INVITATION
    CODE
}

model Tournament {
    id          String                 @id @default(uuid(7))
    name        String
    mode        Mode
    format      TournamentFormat
    status      TournamentStatus       @default(REGISTRATION)
    creatorId   String?
    creator     User?                  @relation(fields: [creatorId], references: [id], onDelete: SetNull)
    maxEntries  Int
    entries     TournamentEntry[]
    entryCode   String                 @unique
    startAt     DateTime
    createdAt   DateTime               @default(now())
    updatedAt   DateTime               @updatedAt
    invitations TournamentInvitation[]
    matches     TournamentMatch[]
}

model TournamentEntry {
    id           String                  @id @default(uuid(7))
    tournamentId String
    tournament   Tournament              @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
    source       EntrySource
    members      TournamentEntryMember[]
    createdAt    DateTime                @default(now())
    asEntryA     TournamentMatch[]       @relation("TournamentMatchEntryA")
    asEntryB     TournamentMatch[]       @relation("TournamentMatchEntryB")
    wonMatches   TournamentMatch[]       @relation("TournamentMatchWinner")
}

model TournamentEntryMember {
    id       String          @id @default(uuid(7))
    entryId  String
    entry    TournamentEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
    userId   String
    user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
    joinedAt DateTime        @default(now())

    @@unique([entryId, userId])
}

model TournamentMatch {
    id              String            @id @default(uuid(7))
    tournamentId    String
    tournament      Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
    round           Int
    slot            Int
    entryAId        String?
    entryA          TournamentEntry?  @relation("TournamentMatchEntryA", fields: [entryAId], references: [id], onDelete: SetNull)
    entryBId        String?
    entryB          TournamentEntry?  @relation("TournamentMatchEntryB", fields: [entryBId], references: [id], onDelete: SetNull)
    winnerEntryId   String?
    winnerEntry     TournamentEntry?  @relation("TournamentMatchWinner", fields: [winnerEntryId], references: [id], onDelete: SetNull)
    nextMatchId     String?
    nextMatch       TournamentMatch?  @relation("TournamentMatchNext", fields: [nextMatchId], references: [id], onDelete: SetNull)
    previousMatches TournamentMatch[] @relation("TournamentMatchNext")
    matchId         String?
    match           Match?            @relation(fields: [matchId], references: [id], onDelete: SetNull)
    createdAt       DateTime          @default(now())
    updatedAt       DateTime          @updatedAt

    @@unique([matchId])
}

model TournamentInvitation {
    id           String           @id @default(uuid(7))
    tournamentId String
    tournament   Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
    inviterId    String
    inviter      User             @relation(name: "TournamentInvitationInviter", fields: [inviterId], references: [id], onDelete: Cascade)
    inviteeId    String
    invitee      User             @relation(name: "TournamentInvitationInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)
    status       InvitationStatus @default(PENDING)
    createdAt    DateTime         @default(now())
    updatedAt    DateTime         @updatedAt

    @@unique([tournamentId, inviteeId])
}
